# ═══════════════════════════════════════════════════════
# SHORTKEY — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ═══════════════════════════════════════════════════════

# ── Site ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# mock | live  (UI hint — also set keys below for live)
NEXT_PUBLIC_COMMERCE_MODE=mock

# stripe | shopify | dual | mock
COMMERCE_PROVIDER=dual

# ── Stripe ────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_

# Optional: pre-create a Price in Stripe for the founding brand fee
# If blank, ad-hoc price_data is used at $FOUNDING_BRAND_FEE_USD
STRIPE_FOUNDING_BRAND_PRICE_ID=price_
FOUNDING_BRAND_FEE_USD=5000

# ── Shopify ───────────────────────────────────────────
# Get from: Shopify Admin → Apps → Custom App → Storefront API
# Store domain format: your-store.myshopify.com (no https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (read products, create carts)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Admin API access token (optional — for webhook verification, inventory)
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Get from: Shopify Admin → Settings → Notifications → Webhooks → Signing secret
SHOPIFY_WEBHOOK_SECRET=

# Shopify API version — update annually
SHOPIFY_API_VERSION=2025-01

# ── TINT Virtual Try-On ───────────────────────────────
# Get from: TINT merchant dashboard
NEXT_PUBLIC_TINT_MERCHANT_ID=

# ═══════════════════════════════════════════════════════
# WIRING CHECKLIST (run through in order):
# 1. Fill STRIPE keys → test founding brand fee on /brands
# 2. Fill SHOPIFY keys → add variant GIDs to src/lib/commerce/sku-map.ts
# 3. Set NEXT_PUBLIC_COMMERCE_MODE=live
# 4. Register webhooks in Stripe + Shopify dashboards
# 5. Set COMMERCE_PROVIDER=dual for both gateways
# ═══════════════════════════════════════════════════════
