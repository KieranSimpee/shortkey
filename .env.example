# Public site URL (used for Stripe/Shopify success + cancel redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# mock | live  — UI hint only; providers also require keys below
NEXT_PUBLIC_COMMERCE_MODE=mock

# stripe | shopify | dual | mock
COMMERCE_PROVIDER=dual

# --- Stripe (consumer cart + founding brand fee) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: Price ID for founding brand fee (else ad-hoc price_data uses FOUNDING_BRAND_FEE_USD)
STRIPE_FOUNDING_BRAND_PRICE_ID=
FOUNDING_BRAND_FEE_USD=5000

# --- Shopify (Storefront checkout for retail SKUs) ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2025-01

# Existing / optional product keys
NEXT_PUBLIC_TINT_MERCHANT_ID=
